# =============================================================================
# CarbonThreat Enterprise — Environment Configuration
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
SERVER_API_PROTOCOL=http
PORT=3000
LOG_LEVEL=warn

# FQDN hostname (required when deploying with a domain)
APP_HOSTNAME=example.com

# TLS (set APP_USE_TLS=true for production; provide cert paths)
APP_USE_TLS=false
APP_PORT=443
APP_TLS_CERT_PATH=/path/to/certificate.pem
APP_TLS_KEY_PATH=/path/to/privatekey.pem

# -----------------------------------------------------------------------------
# PostgreSQL Database
# REQUIRED — no defaults for credentials
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=carbonthreat_user
DB_PASSWORD=CHANGE_ME_generate_strong_password
DB_NAME=carbonthreat

# -----------------------------------------------------------------------------
# Encryption — JWT (existing OAuth token encryption)
# Generate: openssl rand -base64 48
# REQUIRED
# -----------------------------------------------------------------------------
ENCRYPTION_KEYS='[{"isPrimary": true, "id": 0, "value": "CHANGE_ME_32_char_exactly_here!!"}]'
ENCRYPTION_JWT_SIGNING_KEY=CHANGE_ME_generate_with_openssl_rand_base64_48
ENCRYPTION_JWT_REFRESH_SIGNING_KEY=CHANGE_ME_generate_with_openssl_rand_base64_48_different

# -----------------------------------------------------------------------------
# Encryption — Model storage (AES-256-GCM for threat models in PostgreSQL)
# Generate: openssl rand -hex 32
# REQUIRED when using PostgreSQL model storage
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_from_openssl_rand_hex_32

# -----------------------------------------------------------------------------
# AI — Threat Bot (Ollama local LLM)
# OLLAMA_URL: base URL of your Ollama instance
# OLLAMA_MODEL: model tag to use (e.g. llama3, mistral, codellama)
# -----------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=llama3

# -----------------------------------------------------------------------------
# Azure Active Directory (SSO — Phase 3)
# Register an app at https://portal.azure.com > App registrations
# -----------------------------------------------------------------------------
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=CHANGE_ME
AZURE_AD_REDIRECT_URI=http://localhost:3000/api/oauth/azure/return

# -----------------------------------------------------------------------------
# GitHub OAuth (for threat model storage in GitHub repos)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=01234567890123456789
GITHUB_CLIENT_SECRET=0123456789abcdef0123456789abcdef0123456
GITHUB_ENTERPRISE_HOSTNAME=optional_if_using_enterprise
GITHUB_ENTERPRISE_PORT=optional_if_enterprise_and_non_standard
GITHUB_ENTERPRISE_PROTOCOL=optional_if_enterprise_and_non_standard
GITHUB_SCOPE=public_repo

# -----------------------------------------------------------------------------
# GitLab OAuth
# -----------------------------------------------------------------------------
GITLAB_CLIENT_ID=01234567890123456789
GITLAB_CLIENT_SECRET=0123456789abcdef0123456789abcdef0123456
GITLAB_SCOPE=read_user read_repository write_repository profile read_api api
GITLAB_REDIRECT_URI=http://localhost:3000/api/oauth/return

# -----------------------------------------------------------------------------
# Bitbucket OAuth
# -----------------------------------------------------------------------------
BITBUCKET_CLIENT_ID=01234567890123456789
BITBUCKET_CLIENT_SECRET=0123456789abcdef0123456789abcdef0123456
BITBUCKET_SCOPE=repository:write
BITBUCKET_WORKSPACE=workspace_name

# -----------------------------------------------------------------------------
# Google Drive OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=01234567890123456789
GOOGLE_CLIENT_SECRET=0123456789abcdef0123456789abcdef0123456
GOOGLE_SCOPE=openid email profile
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/return
