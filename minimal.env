# =============================================================================
# CarbonThreat — Minimal local-Docker environment
#
# Usage:
#   cp minimal.env .env
#   docker compose up --build
#
# ⚠  These secrets are PRE-GENERATED FOR LOCAL DEVELOPMENT ONLY.
#    Before any public/production deployment, regenerate every key:
#
#   ENCRYPTION_JWT_SIGNING_KEY         → openssl rand -base64 48
#   ENCRYPTION_JWT_REFRESH_SIGNING_KEY → openssl rand -base64 48
#   ENCRYPTION_KEY                     → openssl rand -hex 32
#   ENCRYPTION_KEYS value (32 chars)   → openssl rand -base64 24 | head -c 32
#   DB_PASSWORD                        → openssl rand -base64 24
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
APP_USE_TLS=false
APP_HOSTNAME=localhost

# ── PostgreSQL — used by both the db service and the DATABASE_URL override ────
DB_USER=carbonthreat
DB_PASSWORD=ct_local_mvp_2026
DB_NAME=carbonthreat
# Note: DB_HOST/DB_PORT are ignored in Docker — compose injects DATABASE_URL

# ── JWT signing (min 32 chars, 8+ unique chars) ───────────────────────────────
ENCRYPTION_JWT_SIGNING_KEY=CarbonThreat-LocalDev-JWT-Sign-2026-MVPonly!
ENCRYPTION_JWT_REFRESH_SIGNING_KEY=CarbonThreat-LocalDev-Refresh-2026-MVPonly!

# ── Model encryption (AES-256-GCM) — 64 hex chars = 32 bytes ─────────────────
ENCRYPTION_KEY=74ef6152648a88706506126672a077414b54dc561b5979eba6e82a87f073c341

# ── Legacy OAuth token encryption — exactly 32 chars ─────────────────────────
ENCRYPTION_KEYS=[{"isPrimary": true, "id": 0, "value": "LocalDevKey-CarbonThreat2026-MVP"}]

# ── AI (optional — leave blank to disable) ────────────────────────────────────
OPENAI_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434/v1/chat/completions
OLLAMA_MODEL=llama3

# ── SSO / SAML (optional — leave blank to use local auth only) ───────────────
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=

# ── Git providers (optional — not required for MVP) ───────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_SCOPE=public_repo
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
